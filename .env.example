# sync-app-backend base URL (no trailing slash; /api is appended automatically)
BACKEND_INTERNAL_API_URL=http://127.0.0.1:3000

# Must match sync-app-backend INTERNAL_API_KEY (header: x-internal-api-key)
# Used for GET /api/internal/marketing-ai/upcoming-festivals and POST generate-platform-content
INTERNAL_API_KEY=

# Optional — see src/config/env.ts for defaults
# BRAND_VOICE=Raven: sharp, festival-savvy, community-first...
# CONTENT_TYPE=news
# LANGUAGE is ignored for daily markdown — reports are always generated in English.
# LANGUAGE=en

# --- GitHub Actions (Settings → Secrets and variables → Actions) ---
# Secrets (required for scheduled daily workflow):
#   BACKEND_INTERNAL_API_URL  — e.g. https://sync-backend-prd-269371-9-1442514260.sh.run.tcloudbase.com/api
#   INTERNAL_API_KEY          — same as backend INTERNAL_API_KEY
#   FEISHU_WEBHOOK_URL        — Feishu group custom bot webhook
# Optional repository variables:
#   BRAND_VOICE, CONTENT_TYPE, LANGUAGE
#
# Daily workflow: 08:00 Asia/Shanghai → commit report → notify Feishu (not GitHub Issues).
