# sync-app-backend base URL (no trailing slash)
# Local: http://127.0.0.1:3000
# Production CloudBase: https://your-service.sh.run.tcloudbase.com/api
BACKEND_INTERNAL_API_URL=http://127.0.0.1:3000

# Must match sync-app-backend INTERNAL_API_KEY (header: x-internal-api-key)
INTERNAL_API_KEY=sync-dev-internal-marketing-ai-raven-2026

# Optional — used by CLI daily workflow and Content Engine UI
# BRAND_VOICE=Raven: sharp, festival-savvy, community-first...
# CONTENT_TYPE=news

# Content Engine console (Vite) reads the same vars above via envDir.
# Optional explicit Vite overrides:
# VITE_BACKEND_INTERNAL_API_URL=http://127.0.0.1:3000
# VITE_INTERNAL_API_KEY=sync-dev-internal-marketing-ai-raven-2026
# VITE_BRAND_VOICE=Raven: sharp, festival-savvy...

# --- Quick start ---
# 1. sync-app-backend/.env must have matching INTERNAL_API_KEY + HUNYUAN_API_KEY
# 2. cd sync-app-backend && pnpm run dev:all
# 3\ marketing-agent && npm run preflight
# 4. npm run console:dev  →  http://localhost:5174

# --- GitHub Actions (Settings → Secrets) ---
# BACKEND_INTERNAL_API_URL, INTERNAL_API_KEY, FEISHU_WEBHOOK_URL
